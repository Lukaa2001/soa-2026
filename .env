# Shared secrets / config for all services (used by docker-compose)
JWT_KEY=explorer_secret_key
JWT_ISSUER=explorer
JWT_AUDIENCE=explorer-front.com

# PostgreSQL (one role/password reused by the isolated per-service DB containers)
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=super
DATABASE_PORT=5432

# MongoDB (Blog)
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=super

# Neo4j (Followers)
NEO4J_AUTH=neo4j/superSecret123

# CORS origin(s) the gateway accepts from the browser client
GATEWAY_CORS_ORIGINS=http://localhost:4200
